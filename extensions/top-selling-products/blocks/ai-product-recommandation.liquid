<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
{{ 'ai-product-recomandation.css' | asset_url | stylesheet_tag }}

<div
  id="ai-product-chatbot-{{ block.id }}"
  data-ai-product-chatbot
  data-products-url="{{ routes.root_url }}products.json?limit=50"
>
  <div class="container_custom">
    <header class="header_custom">
      <div class="header-title_custom">
        <h1>Digi</h1>
      </div>
      <div class="controls">
        <button class="theme-toggle" type="button" aria-label="Close chatbot">
          <i class="fa-solid fa-x"></i>
        </button>
      </div>
    </header>

    <div class="chat-container">
      <div class="message bot-message">
        <div class="avatar">AI</div>
        <div class="message-bubble">
          <div class="message-content">
            <p>Hello and welcome to Digi. What is your name, and which category product do you need today?</p>
          </div>
        </div>
      </div>
    </div>

    <div class="typing-indicator">
      <div class="typing-dots">
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
      </div>
    </div>

    <div class="input-container">
      <div class="input-wrapper">
        <input
          type="text"
          class="message-input"
          placeholder="Ask for products like shoes, bags, skincare..."
          aria-label="Message input"
        >
        <div class="action-buttons">
          <button class="send-button" type="button" aria-label="Send message">
            <i class="fas fa-paper-plane"></i>
          </button>
        </div>
      </div>
    </div>
  </div>

  <button class="chatbot-toggle" type="button" aria-label="Open chatbot">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
      <path d="M0 0h24v24H0V0z" fill="none"></path>
      <path d="M15 4v7H5.17l-.59.59-.58.58V4h11m1-2H3c-.55 0-1 .45-1 1v14l4-4h10c.55 0 1-.45 1-1V3c0-.55-.45-1-1-1zm5 4h-2v9H6v2c0 .55.45 1 1 1h11l4 4V7c0-.55-.45-1-1-1z"></path>
    </svg>
  </button>
</div>

<script src="{{ 'ai-product-recommandation.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "AI Recommendation Test",
  "target": "body",
  "settings": []
}
{% endschema %}
